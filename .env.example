TELEGRAM_BOT_TOKEN=替换成你的 Telegram Bot Token
AUTHORIZED_TELEGRAM_USER_IDS=替换成你的 Telegram 用户 ID，多个用逗号分隔
TELEDEX_STATE_DIR=./data
TELEDEX_POLL_TIMEOUT_SECONDS=30
TELEDEX_PREVIEW_UPDATE_INTERVAL_SECONDS=60.0
TELEDEX_CODEX_BIN=codex
TELEDEX_CODEX_EXEC_MODE=full-auto
TELEDEX_CODEX_MODEL=
TELEDEX_CODEX_ENABLE_SEARCH=false
TELEDEX_CODEX_PERSIST_EXTENDED_HISTORY=true
TELEDEX_TMUX_BIN=tmux
TELEDEX_TMUX_SHELL=/bin/bash
TELEDEX_LOG_LEVEL=INFO
